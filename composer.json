{
    "name": "fatjon-lleshi/antares-router",
    "description": "Lightweight attribute-based router for PHP 8.2+",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Antares\\Router\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Fatjon-Lleshi",
            "email": "johnlesis91@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "nikic/fast-route": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"

    },
    "suggest": {
        "symfony/yaml": "Required for YAML route configuration (^6.0)"
    },
    "keywords": ["router", "routing", "http", "rest", "attributes", "php"],
    "homepage": "https://github.com/johnlesis/antares-router",
    "support": {
        "issues": "https://github.com/johnlesis/antares-router/issues",
        "source": "https://github.com/johnlesis/antares-router"
    }
}
